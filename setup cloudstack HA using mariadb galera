6.4 Initialize database — run on node1 only
bash# On node1 only
cloudstack-setup-databases cloud:cloudpassword@192.168.0.182 \
    --deploy-as=root \
    -e file \
    -m $(hostname -I | awk '{print $1}') \
    -k $(hostname -I | awk '{print $1}')
6.5 Setup management on both nodes
bashcloudstack-setup-management
6.6 Start CloudStack management
bash# Start node1 first
systemctl enable --now cloudstack-management   # on node1

# Wait for node1 to fully start then start node2
tail -f /var/log/cloudstack/management/management-server.log | grep "Successfully"

# Then start node2
systemctl enable --now cloudstack-management   # on node2

