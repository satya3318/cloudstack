db.cloud.host=192.168.0.182
db.cloud.port=3306
db.cloud.name=cloud
db.cloud.username=cloud
db.cloud.password=cloudpassword
db.cloud.autoReconnect=true
db.usage.host=192.168.0.182
db.usage.port=3306
db.usage.name=cloud_usage
db.usage.username=cloud
