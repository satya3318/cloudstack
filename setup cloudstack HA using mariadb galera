PHASE 8 — Failover Testing
Test 1 — DB failure on node1
bashsystemctl stop mariadb              # on node1
journalctl -u haproxy -f | grep galera
# Expect: galera1 DOWN, traffic moves to galera2
mariadb -u cloud -p -h 192.168.0.182 -e "SELECT 1;"   # must still work
systemctl start mariadb             # restore node1
Test 2 — Management failure on node1
bashsystemctl stop cloudstack-management    # on node1
journalctl -u haproxy -f | grep cloudstack
# Expect: cs-mgmt1 DOWN, traffic moves to cs-mgmt2
curl -I http://192.168.0.182:8089/client   # must still work
systemctl start cloudstack-management   # restore node1
Test 3 — Full node1 failure
bash# Simulate by stopping all services on node1
systemctl stop cloudstack-management mariadb keepalived haproxy

# On node2 — VIP should appear within 2-3 seconds
ip addr show ens160 | grep 192.168.0.182

# Portal must be accessible
curl -I http://192.168.0.182:8089/client

# Restore node1
systemctl start keepalived haproxy mariadb cloudstack-management

Recovery Procedures
Galera cluster recovery after both nodes down
bash# On both nodes — check grastate.dat
cat /var/lib/mysql/grastate.dat

# Find most advanced node
mysqld_safe --wsrep-recover 2>&1 | grep "Recovered position"

# On node with highest seqno — set safe_to_bootstrap
vi /var/lib/mysql/grastate.dat
# Set: safe_to_bootstrap: 1

# Bootstrap from that node
galera_new_cluster

# Join other node normally
systemctl start mariadb    # on other node

